# Required
POSTGRES_PASSWORD=changeme
SECRET_KEY=changeme_generate_random_50_chars
BROADCAST_WEBSOCKET_SECRET=changeme_generate_random_50_chars
DJANGO_SUPERUSER_PASSWORD=changeme
CSRF_TRUSTED_ORIGINS=https://forge.example.com

# Optional
POSTGRES_USER=forge
POSTGRES_DB=forge
REDIS_URL=redis://redis:6379/0
DJANGO_SETTINGS_MODULE=forge.settings.production

# Docker images
BACKEND_IMAGE=krlex/forge-backend
FRONTEND_IMAGE=krlex/forge-frontend
VERSION=latest
